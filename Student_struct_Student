#include <stdio.h>

// Defining the attributes of a Student
struct Student {
    int rollNo;
    char name[50];
    float marks;
};

// Function to display the student's details
void displayStudent(struct Student s) {
    printf("\n--- Student Details ---\n");
    printf("Roll Number: %d\n", s.rollNo);
    printf("Name       : %s\n", s.name);
    printf("Marks      : %.2f%%\n", s.marks);
}

int main() {
    struct Student s1; // Creating a student object

    // Taking input for the attributes
    printf("Enter Roll Number: ");
    scanf("%d", &s1.rollNo);
    
    printf("Enter Name: ");
    scanf("%s", s1.name); // Note: Stops at the first space
    
    printf("Enter Marks: ");
    scanf("%f", &s1.marks);

    // Passing the structure to the function
    displayStudent(s1);

    return 0;
}
